---
permalink: feed.xml
eleventyExcludeFromCollections: true
metadata:
  title: Samyak's Blog
  subtitle: Compiler dev, low level programming and random thoughts
  url: https://smyk07.github.io
  author:
    name: Samyak
    email: bambole@duck.com
language: en
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
<channel>
  <title>{{ metadata.title }}</title>
  <description>{{ metadata.subtitle }}</description>
  <link>{{ metadata.url }}</link>
  <atom:link href="{{ metadata.url }}/feed.xml" rel="self" type="application/rss+xml" />

  {% for post in collections.posts | reverse %}
  <item>
    <title>{{ post.data.title }}</title>
    <link>{{ metadata.url }}{{ post.url }}</link>
    <guid>{{ metadata.url }}{{ post.url }}</guid>
    <pubDate>{{ post.date.toUTCString() }}</pubDate>
    <description><![CDATA[
      {{ post.content | safe }}
    ]]></description>
  </item>
  {% endfor %}

</channel>
</rss>
